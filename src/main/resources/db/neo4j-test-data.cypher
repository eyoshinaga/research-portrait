  [381, 478]
] AS pair
MATCH (r1:Researcher {id: pair[0]}), (r2:Researcher {id: pair[1]})
CREATE (r1)-[:COOPERATE_WITH]->(r2);

// 11. 创建权重配置节点 (WeightConfig)
